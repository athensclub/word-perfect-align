<?xml version="1.0" encoding="UTF-8"?>
<!--
  Office Add-in manifest (XML / v1.1 schema) for a Word Task Pane add-in.
  Targets Word (desktop + Word on the web / SharePoint).
  All resources are served from https://word-perfect-align.kawinr.com
-->
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
  xsi:type="TaskPaneApp">

  <!-- Unique GUID for this add-in. Generate a fresh one per add-in. -->
  <Id>4f36d097-1e1e-429f-8a34-8fed4a84ca56</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Perfect Align</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Perfect Align" />
  <Description DefaultValue="Dynamically aligns mixed nested lists so each layer's bullet/number sits under the parent layer's text." />
  <IconUrl DefaultValue="https://word-perfect-align.kawinr.com/assets/icon-32.png" />
  <HighResolutionIconUrl DefaultValue="https://word-perfect-align.kawinr.com/assets/icon-80.png" />
  <SupportUrl DefaultValue="https://word-perfect-align.kawinr.com/" />

  <!-- Restrict the add-in to Word. -->
  <Hosts>
    <Host Name="Document" />
  </Hosts>

  <!-- Require the Word API set that exposes leftIndent / firstLineIndent / listItem. -->
  <Requirements>
    <Sets DefaultMinVersion="1.3">
      <Set Name="WordApi" MinVersion="1.3" />
    </Sets>
  </Requirements>

  <!-- Fallback task pane location for older clients. -->
  <DefaultSettings>
    <SourceLocation DefaultValue="https://word-perfect-align.kawinr.com/src/taskpane.html" />
  </DefaultSettings>

  <!-- Read + write the document so we can update paragraph indentation. -->
  <Permissions>ReadWriteDocument</Permissions>

  <!-- Modern ribbon integration (button on the Home tab). -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Document">
        <DesktopFormFactor>
          <!-- No function-file commands are needed; the button just opens the task pane. -->
          <GetStarted>
            <Title resid="GetStarted.Title" />
            <Description resid="GetStarted.Description" />
            <LearnMoreUrl resid="GetStarted.LearnMoreUrl" />
          </GetStarted>

          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="PerfectAlign.Group">
                <Label resid="Group.Label" />
                <Icon>
                  <bt:Image size="16" resid="Icon.16" />
                  <bt:Image size="32" resid="Icon.32" />
                  <bt:Image size="80" resid="Icon.80" />
                </Icon>
                <Control xsi:type="Button" id="PerfectAlign.Button">
                  <Label resid="Button.Label" />
                  <Supertip>
                    <Title resid="Button.Label" />
                    <Description resid="Button.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16" />
                    <bt:Image size="32" resid="Icon.32" />
                    <bt:Image size="80" resid="Icon.80" />
                  </Icon>
                  <!-- Open the task pane UI when clicked. -->
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ButtonId1</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url" />
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16" DefaultValue="https://word-perfect-align.kawinr.com/assets/icon-16.png" />
        <bt:Image id="Icon.32" DefaultValue="https://word-perfect-align.kawinr.com/assets/icon-32.png" />
        <bt:Image id="Icon.80" DefaultValue="https://word-perfect-align.kawinr.com/assets/icon-80.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Taskpane.Url" DefaultValue="https://word-perfect-align.kawinr.com/src/taskpane.html" />
        <bt:Url id="GetStarted.LearnMoreUrl" DefaultValue="https://word-perfect-align.kawinr.com/" />
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GetStarted.Title" DefaultValue="Perfect Align is ready." />
        <bt:String id="Group.Label" DefaultValue="Perfect Align" />
        <bt:String id="Button.Label" DefaultValue="Align Lists" />
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="GetStarted.Description" DefaultValue="Open the Perfect Align task pane from the Home tab, select your nested list, and click Perfectly Align Selection." />
        <bt:String id="Button.Tooltip" DefaultValue="Open the Perfect Align task pane to align a mixed nested list selection." />
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
