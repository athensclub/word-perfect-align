{
  "name": "word-align-addin",
  "version": "1.0.0",
  "description": "Word Online add-in that dynamically aligns mixed nested lists so each layer's bullet/number sits under the parent layer's text.",
  "private": true,
  "author": "Kawin Rattanapun",
  "license": "MIT",
  "scripts": {
    "certs": "office-addin-dev-certs install",
    "start": "office-addin-dev-certs install && node server.js",
    "serve": "node server.js",
    "test": "node --test",
    "typecheck": "tsc -p tsconfig.json",
    "validate": "office-addin-manifest validate manifest.xml"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/office-js": "^1.0.0",
    "office-addin-dev-certs": "^1.13.0",
    "office-addin-manifest": "^1.13.0",
    "typescript": "^5.6.0"
  }
}
